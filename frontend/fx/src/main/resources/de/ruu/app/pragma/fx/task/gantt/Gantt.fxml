<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TreeTableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
            maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308">
    <VBox AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">

        <!-- Top bar: group + date range -->
        <HBox alignment="CENTER_LEFT" spacing="8">
            <padding><Insets top="5" right="5" bottom="5" left="5"/></padding>
            <Label text="group"/>
            <ComboBox fx:id="cbGroups" minWidth="180"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="from"/>
            <DatePicker fx:id="dtPckrStart" prefWidth="140"/>
            <Label text="to"/>
            <DatePicker fx:id="dtPckrEnd" prefWidth="140"/>
            <Button fx:id="btnApply" text="apply" style="-fx-font-size: 11px;" prefHeight="26"/>
        </HBox>

        <!-- Gantt TreeTableView -->
        <TreeTableView fx:id="ttv" VBox.vgrow="ALWAYS"
                       maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
                       showRoot="false" style="-fx-table-cell-border-color: transparent;"/>

        <!-- Detail / date editing area for selected task -->
        <HBox alignment="CENTER_LEFT" spacing="8">
            <padding><Insets top="4" right="5" bottom="5" left="5"/></padding>
            <Label text="planned start"/>
            <DatePicker fx:id="dtPckrTaskStart" prefWidth="140"/>
            <Label text="planned end"/>
            <DatePicker fx:id="dtPckrTaskEnd" prefWidth="140"/>
            <Button fx:id="btnSaveDates" text="save"
                    style="-fx-font-size: 11px;" prefHeight="26"/>
        </HBox>

    </VBox>
</AnchorPane>
